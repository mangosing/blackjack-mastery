{
  "name": "blackjack-mastery",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "turbo format",
    "clean": "turbo clean",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format:check": "turbo format:check",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter web exec eslint --fix",
      "pnpm --filter web exec prettier --write"
    ],
    "apps/api/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter api exec eslint --fix",
      "pnpm --filter api exec prettier --write"
    ],
    "*.{json,md,css}": [
      "pnpm exec prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "turbo": "^2.10.3",
    "vitest": "^4.1.9"
  }
}
